# ============================================================
# trace_weaver — root .gitignore
# 프로젝트 단계: 기획/리서치 (docs 위주). 향후 코드 추가 대비
# 다중 언어/툴체인 ignore 패턴을 함께 포함한다.
# ============================================================

# --- Session/Agent memory & tooling artifacts ----------------
# .remember/ 는 Claude 세션 메모리(휘발성). 통째로 제외.
.remember/
# Claude Code per-project 설정/캐시도 추적하지 않음
.claude/
.codex/
.cursor/

# --- OS ------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editors / IDEs ------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.netrwhist
*.sublime-project
*.sublime-workspace

# --- Env & secrets ------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials.json
.secret
.secrets

# --- Logs & temp --------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.orig

# --- Python -------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/
downloads/
parts/
sdist/
wheels/
share/python-wheels/
MANIFEST
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json
.ipynb_checkpoints/
.venv/
venv/
env/
ENV/
.python-version

# --- Node.js / TypeScript -----------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn/
.pnpm-store/
.next/
.nuxt/
.turbo/
.cache/
coverage/
*.tsbuildinfo
.eslintcache

# --- Rust ---------------------------------------------------
target/
Cargo.lock.bak
**/*.rs.bk

# --- C/C++ --------------------------------------------------
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.gch
*.pch
*.d
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
compile_commands.json
.cache/clangd/
.clangd/

# --- Go -----------------------------------------------------
vendor/
*.test
*.prof

# --- Java / Gradle / Maven ----------------------------------
*.class
*.jar
*.war
*.ear
hs_err_pid*
.gradle/
gradle-app.setting
target/
.mvn/
mvnw
mvnw.cmd

# --- Docker / Containers ------------------------------------
*.pid
.docker/

# --- Misc tooling -------------------------------------------
.history/
.vagrant/
.terraform/
*.tfstate
*.tfstate.backup

# --- Project-local data dumps -------------------------------
# 트레이스/관측 데이터처럼 큰 산출물은 추적하지 않는다 (필요 시 화이트리스트)
data/
out/
output/
artifacts/
trace/
traces/
*.parquet
*.sqlite
*.sqlite3
*.db
